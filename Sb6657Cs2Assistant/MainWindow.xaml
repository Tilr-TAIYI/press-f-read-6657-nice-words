<Window x:Class="Sb6657Cs2Assistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CS2 烂梗助手" Width="1060" Height="720" MinWidth="860" MinHeight="600"
        Background="#F4F6F7" FontFamily="Microsoft YaHei UI" FontSize="13"
        Closing="Window_Closing" PreviewKeyDown="Window_PreviewKeyDown">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0"><TextBlock Foreground="#68747C" Text="助手状态"/><TextBlock x:Name="RunStatusText" FontSize="19" FontWeight="SemiBold" Text="已暂停"/></StackPanel>
        <StackPanel Grid.Column="1"><TextBlock Foreground="#68747C" Text="CS2 状态"/><TextBlock x:Name="GameStatusText" FontSize="19" FontWeight="SemiBold" Text="未运行"/></StackPanel>
        <StackPanel Grid.Column="2"><TextBlock Foreground="#68747C" Text="网络状态"/><TextBlock x:Name="NetworkStatusText" FontSize="19" FontWeight="SemiBold" Text="等待请求"/></StackPanel>
        <StackPanel Grid.Column="3"><TextBlock Foreground="#68747C" Text="下次复制"/><TextBlock x:Name="CountdownText" FontSize="19" FontWeight="SemiBold" Text="--"/></StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Margin="0,12" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
      <StackPanel Orientation="Horizontal">
        <Button x:Name="StartButton" Content="启动" Click="Start_Click" Background="#167D6A" Foreground="White" BorderBrush="#167D6A"/>
        <Button x:Name="PauseButton" Content="暂停" Click="Pause_Click" IsEnabled="False"/>
        <Button Content="立即复制" Click="SendNow_Click"/>
        <Button Content="刷新标签" Click="RefreshTags_Click"/>
        <TextBlock x:Name="HotkeyHintText" Margin="12,8,0,0" Foreground="#68747C" Text="启动后定时复制当前文本；请在游戏聊天框内粘贴并发送。"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions><ColumnDefinition Width="330"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <TextBlock FontSize="16" FontWeight="SemiBold" Text="标签筛选"/>
          <TextBox x:Name="TagSearchBox" Grid.Row="1" Margin="0,10" TextChanged="TagSearch_TextChanged" ToolTip="搜索标签"/>
          <ListBox x:Name="TagsList" Grid.Row="2" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <CheckBox Margin="3,5" Content="{Binding DictLabel}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Checked="TagSelection_Changed" Unchecked="TagSelection_Changed"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="全部（不限制）" Click="SelectAllTags_Click"/>
            <Button Content="清空" Click="ClearTags_Click"/>
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Column="2">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
          <StackPanel>
            <TextBlock FontSize="16" FontWeight="SemiBold" Text="当前内容"/>
            <TextBlock x:Name="CurrentMemeText" Margin="0,10,0,5" FontSize="17" TextWrapping="Wrap" Text="等待获取sb6657烂梗"/>
            <TextBlock x:Name="CurrentMetaText" Foreground="#68747C" Text="ID: --    候选数量: --"/>
          </StackPanel>
        </Border>
        <Border Grid.Row="1" Margin="0,12" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"><TextBlock Foreground="#68747C" Text="复制/触发"/><TextBlock x:Name="SuccessText" FontSize="18" Text="0"/></StackPanel>
            <StackPanel Grid.Column="1"><TextBlock Foreground="#68747C" Text="跳过"/><TextBlock x:Name="SkippedText" FontSize="18" Text="0"/></StackPanel>
            <StackPanel Grid.Column="2"><TextBlock Foreground="#68747C" Text="失败"/><TextBlock x:Name="FailedText" FontSize="18" Text="0"/></StackPanel>
            <StackPanel Grid.Column="3"><TextBlock Foreground="#68747C" Text="重复重抽"/><TextBlock x:Name="RedrawnText" FontSize="18" Text="0"/></StackPanel>
          </Grid>
        </Border>
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
          <TabControl BorderThickness="0">
            <TabItem Header="事件日志">
              <DockPanel Margin="4">
                <Button DockPanel.Dock="Top" Content="清空日志" HorizontalAlignment="Right" Margin="0,0,0,6" Click="ClearLog_Click"/>
                <ListBox x:Name="LogList" BorderThickness="0" FontFamily="Consolas, Microsoft YaHei UI"/>
              </DockPanel>
            </TabItem>
            <TabItem Header="发送历史">
              <ListBox x:Name="HistoryList" Margin="4" BorderThickness="0" FontFamily="Consolas, Microsoft YaHei UI"/>
            </TabItem>
          </TabControl>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="3" Margin="0,12,0,0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
      <StackPanel>
        <WrapPanel>
          <TextBlock Margin="4,5" Text="间隔(秒，≥10)"/><TextBox x:Name="IntervalBox" Width="48" Margin="5,0,14,0" LostFocus="Settings_LostFocus"/>
          <TextBlock Margin="4,5" Text="超时(秒)"/><TextBox x:Name="TimeoutBox" Width="48" Margin="5,0,14,0" LostFocus="Settings_LostFocus"/>
          <TextBlock Margin="4,5" Text="发送键"/><Button x:Name="CaptureKeyButton" Content="F8" Width="75" Click="CaptureKey_Click"/>
          <TextBlock Margin="4,5" Text="频道"/><ComboBox x:Name="ChannelBox" Width="95" Margin="5,0,14,0" SelectionChanged="Channel_Changed"><ComboBoxItem Content="全体聊天" Tag="All"/><ComboBoxItem Content="队内聊天" Tag="Team"/></ComboBox>
          <TextBlock Margin="4,5" Text="启停热键"/><TextBox x:Name="HotkeyBox" Width="105" Margin="5,0,14,0" LostFocus="Settings_LostFocus"/>
          <TextBlock Margin="4,5" Text="前缀"/><TextBox x:Name="PrefixBox" Width="110" Margin="5,0,14,0" LostFocus="Settings_LostFocus"/>
          <TextBlock Margin="4,5" Text="最大长度"/><TextBox x:Name="MaxLengthBox" Width="58" Margin="5,0" LostFocus="Settings_LostFocus"/>
        </WrapPanel>
        <WrapPanel Margin="0,8,0,0">
          <TextBlock Margin="4,5" Text="Steam"/><TextBox x:Name="SteamPathBox" Width="210" Margin="5,0" IsReadOnly="True"/>
          <Button Content="自动检测" Click="DetectInstall_Click"/><Button Content="选择 Steam" Click="BrowseSteam_Click"/>
          <TextBlock Margin="4,5" Text="CS2"/><TextBox x:Name="Cs2PathBox" Width="250" Margin="5,0" IsReadOnly="True"/>
          <Button Content="选择 CS2" Click="BrowseCs2_Click"/>
          <Button Content="应用按键绑定" Click="ApplyBinding_Click"/>
          <Button Content="测试接口" Click="TestApi_Click"/>
          <Button Content="删除本工具 CFG" Click="RemoveCfg_Click"/>
        </WrapPanel>
      </StackPanel>
    </Border>
  </Grid>
</Window>
